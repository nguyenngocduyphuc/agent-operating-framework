# AOF workspace root — set to your monorepo root.
# If unset, AOF discovers it from the marker file.
# export AOF_WORKSPACE=/path/to/your/workspace

# Asana personal access token (for task tracking).
# Generate at https://app.asana.com/0/developer-console
# ASANA_TOKEN=your_asana_token_here

# Generic tracker hook used by core/mcp_server.py post_evidence and adapters/asana_adapter.py.
# When BOTH are set, post_evidence also posts a real comment (and completes the task on success).
# The local audit log is always written regardless — the tracker post is additive and fail-soft.
# TRACKER_TYPE=asana
# TRACKER_TOKEN=your_asana_token_here

# GitHub token (for PR/issue operations via CLI).
# GITHUB_TOKEN=your_github_token_here

# Audit log directory. Defaults to ~/.npflight.
# AOF_AUDIT_DIR=~/.npflight

# Python interpreter. Defaults to "python3".
# Set if your venv uses a different binary.
# AOF_PYTHON=.venv/bin/python3

# Log level for AOF internals. One of: DEBUG, INFO, WARN, ERROR.
# AOF_LOG_LEVEL=INFO
