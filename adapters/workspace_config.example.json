{
  "workspace_name": "my-project",

  "require_asana_task": false,
  "require_contract": true,
  "require_evidence": true,
  "require_handoff": true,

  "credential_groups": {
    "Asana": ["ASANA_TOKEN"],
    "GitHub": ["GITHUB_TOKEN"]
  },

  "gates": {
    "ruff": ["ruff", "check", "."],
    "pytest": ["{python}", "-m", "pytest", "tests/", "-x", "-q"]
  }
}
// workspace_name:         human-readable label for the workspace.
// require_asana_task:      if true, preflight blocks when no Asana task GID is provided.
// require_contract:        if true, every task needs a written Execution Contract.
// require_evidence:        if true, post-task evidence comment is mandatory.
// require_handoff:         if true, session handoff must be written before closing.
// credential_groups:       maps group names to env var keys needed by that group.
//                          Preflight checks that the vars are set.
// gates:                  names → CLI command arrays (list of strings).
//                          "{python}" is replaced with the configured Python binary.
